Bootstrap: docker
From: debian:trixie

%post
export DEBIAN_FRONTEND=noninteractive
    apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends --no-install-suggests \
    unzip
    apt-get clean && rm -rf /var/lib/apt/lists/*

%environment
    export LC_ALL=C.UTF-8
