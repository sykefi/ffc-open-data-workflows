Bootstrap: docker
From: debian:forky

%post
    export DEBIAN_FRONTEND=noninteractive
    apt update && \
    apt upgrade -y && \
    apt install -y --no-install-recommends --no-install-suggests \
    bison \
    build-essential \
    bzip2 \
    ca-certificates \
    cmake \
    curl \
    flex \
    g++ \
    gcc \
    gdal-bin \
    git \
    libbz2-dev \
    libcairo2 \
    libcairo2-dev \
    libcurl4-gnutls-dev \
    libfftw3-bin \
    libfftw3-dev \
    libfreetype-dev \
    libgdal-dev \
    libgeos-dev \
    libgsl0-dev \
    libjpeg-dev \
    libjsoncpp-dev \
    liblapacke-dev \
    libncurses-dev \
    libnetcdf-dev \
    libopenblas-dev \
    libopenblas-openmp-dev \
    libopenjp2-7 \
    libopenjp2-7-dev \
    libpnglite-dev \
    libpq-dev \
    libproj-dev \
    libpython3-all-dev \
    libsqlite3-dev \
    libtiff-dev \
    libzstd-dev \
    locales \
    make \
    mesa-common-dev \
    moreutils \
    ncurses-bin \
    netcdf-bin \
    proj-bin \
    proj-data \
    python-is-python3 \
    python3 \
    python3-dateutil \
    python3-dev \
    python3-magic \
    python3-numpy \
    python3-pil \
    python3-pip \
    python3-setuptools \
    python3-venv \
    sqlite3 \
    subversion \
    unzip \
    vim \
    wget \
    zip \
    zlib1g-dev \
    && apt clean

    wget --output-document=grass-source.zip https://github.com/OSGeo/grass/archive/bb952f0fd0c8275f41aed5ce18038e260585eea4.zip
    unzip grass-source.zip && rm grass-source.zip && mv grass-*/ grass-source && cd grass-source/

    CFLAGS=-O2 ./configure \
    --with-openmp=yes \
    --with-blas=openblas \
    --with-lapack=openblas \
    --with-pthread=yes \
    --with-pdal=no \
    --with-opengl=no \
    --with-proj-share=/usr/share/proj

    make
    make install

    cd /

    rm -rf /grass-source

    projsync --system-directory --source-id fi_nls

%environment
    export LC_ALL=C.UTF-8
